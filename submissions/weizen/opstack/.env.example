# OP Stack L2 sync node config (chain 20260619 · L1 = Sepolia)
# คัดลอกเป็น .env แล้วเติมค่าจริง

# L1 (Sepolia) — execution RPC + beacon (blob) endpoint
L1_RPC=https://ethereum-sepolia-rpc.publicnode.com
L1_BEACON=https://ethereum-sepolia-beacon-api.publicnode.com

# sequencer ของ server (op-node RPC + p2p enode) — เอาจากผู้รัน sequencer
SEQUENCER_HTTP=http://141.11.156.4:8547
SEQUENCER_P2P=/ip4/141.11.156.4/tcp/9222/p2p/<sequencer-op-node-peer-id>

# execution client: geth (default) หรือ reth
EXEC=geth
