# Copy to .env and fill in. NEVER commit .env.
# All values are required unless marked optional.

# Foundry deploy (script/Deploy.s.sol)
DEPLOYER_PK=0x...
SIGNER_ADDR=0x...
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHERSCAN_API_KEY=
INITIAL_DEPOSIT_WEI=50000000000000000   # 0.05 ETH — optional
INITIAL_STAKE_WEI=10000000000000000     # 0.01 ETH — optional
UNSTAKE_DELAY_SEC=86400                 # 1 day  — optional

# Runtime API (docker-compose.yml / api/server.ts)
SIGNER_PK=0x...
PAYMASTER_ADDR=0x...                    # populated after Deploy.s.sol completes
CHAIN_ID=11155111
ALLOWLIST=                              # comma-sep lowercased; empty = open
PORT=8642
LOG_LEVEL=info
